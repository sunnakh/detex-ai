ml/fine-tune/.data/

# LoRA checkpoint directory — large safetensors weights, not results
checkpoints/

# ── ML Results — TRACKED so GPU server can push & laptop can pull ──
# ml/train/artifacts/ is intentionally NOT ignored.
# Tracked outputs:
#   artifacts/models/*.joblib           — trained & calibrated classifiers
#   artifacts/production_model.joblib   — best model selected by select_model.py
#   artifacts/ensemble_weights.json     — AUC-weighted ensemble weights
#   artifacts/model_selection.json      — winner + full comparison table
#   artifacts/optimal_threshold.json    — threshold config for FastAPI backend
#   artifacts/eval/*.json               — per-classifier metrics
#   artifacts/eval/*.png                — ROC, PR, calibration, threshold plots
# NOT tracked (too large — regenerated by pipeline):
#   artifacts/clf_X_train.npy
#   artifacts/clf_X_test.npy

